<Window x:Class="Overlord_PackageManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="700" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menüzeile -->
            <RowDefinition Height="*"/>
            <!-- Hauptinhalt -->
            <RowDefinition Height="Auto"/>
            <!-- Status/Footer (Optional) -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="White" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New" />
                <MenuItem Header="_Open" Click="Browse_File_Click" />
                <MenuItem Header="_Save" Click="Save" />
                <Separator />
                <MenuItem Header="_Export Assets" Click="ExportAssets" />
                <Separator />
                <MenuItem Header="_Exit" Click="Exit" />
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Feste Breite für TreeView -->
                <ColumnDefinition Width="*"/>
                <!-- Dynamische Breite für Editor -->
            </Grid.ColumnDefinitions>

            <!-- TreeView links -->
            <TreeView x:Name="treeView" 
                      Margin="10" 
                      SelectedItemChanged="TreeView_SelectedItemChanged"/>

            <!-- Editor rechts -->
            <Border Grid.Column="1"
                    Margin="0,10,10,10"
                    BorderBrush="#444444" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Background="#F5F5F5"
                    Padding="5">
                <ContentControl Name="EditorHost" />
            </Border>
        </Grid>
    </Grid>
</Window>