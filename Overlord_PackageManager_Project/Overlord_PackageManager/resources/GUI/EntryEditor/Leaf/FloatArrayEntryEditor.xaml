<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.FloatArrayEntryEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">

        <TextBlock Text="Float Array"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Height="200">

            <UniformGrid Name="FloatGrid"
                         Columns="4"/>

        </ScrollViewer>

    </StackPanel>

</UserControl>