<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.MeshBoneShapeEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Overlord_PackageManager.resources.GUI.EntryEditor.Leaf"
             mc:Ignorable="d">

    <Border Padding="10">
        <StackPanel>

            <TextBlock x:Name="LabelBlock"
                       Text="Mesh Bone Shape"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Matrix"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

            <local:Matrix3x3Editor x:Name="MatrixEditor"
                                   Margin="0,0,0,20"/>

            <TextBlock Text="Head"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

            <local:Vector3Editor x:Name="HeadEditor"
                                 Margin="0,0,0,20"/>

            <TextBlock Text="Tail"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

            <local:Vector3Editor x:Name="TailEditor"/>

        </StackPanel>
    </Border>

</UserControl>