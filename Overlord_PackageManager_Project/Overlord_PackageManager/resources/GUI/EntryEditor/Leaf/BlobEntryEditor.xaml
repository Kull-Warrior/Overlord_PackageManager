<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.BlobEntryEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hex Viewer -->
        <ListBox Name="HexList"
                 Grid.Row="0"
                 FontFamily="Consolas"
                 FontSize="13"
                 VirtualizingPanel.IsVirtualizing="True"
                 ScrollViewer.CanContentScroll="True">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <TextBlock Text="{Binding Offset, StringFormat=X8}"
                                   Width="80"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding Hex}"
                                   Width="380"
                                   Margin="10,0,0,0"/>

                        <TextBlock Text="{Binding Ascii}"
                                   Margin="10,0,0,0"
                                   Foreground="DarkSlateGray"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="Export .bin"
            Grid.Column="0"
            Margin="0,0,5,0"
            Click="Export_Click"/>

            <Button Content="Import .bin"
            Grid.Column="1"
            Margin="5,0,0,0"
            Click="Import_Click"/>
        </Grid>
    </Grid>
</UserControl>