<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.UInt16ArrayEntryEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Mesh Index Array (UInt16)" 
                   FontWeight="Bold" 
                   Margin="0,0,0,5"
                   Grid.Row="0"/>

        <ListBox Name="IndexListBox" 
                 Grid.Row="1"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VerticalAlignment="Stretch"
                 HorizontalContentAlignment="Stretch">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <UniformGrid Columns="3">
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Indices[0].Label}" FontSize="9" Foreground="Gray"/>
                            <TextBox Text="{Binding Indices[0].Value, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Indices[1].Label}" FontSize="9" Foreground="Gray"/>
                            <TextBox Text="{Binding Indices[1].Value, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Indices[2].Label}" FontSize="9" Foreground="Gray"/>
                            <TextBox Text="{Binding Indices[2].Value, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </UniformGrid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>