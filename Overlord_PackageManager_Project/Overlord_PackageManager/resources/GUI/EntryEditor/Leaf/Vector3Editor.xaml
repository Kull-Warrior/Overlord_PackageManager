<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.Vector3Editor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="10">
        <StackPanel>

            <TextBlock x:Name="LabelBlock"
                       Text="Vector3"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="X" FontWeight="SemiBold"/>
                        <TextBox x:Name="XBox"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Y" FontWeight="SemiBold"/>
                        <TextBox x:Name="YBox"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Z" FontWeight="SemiBold"/>
                        <TextBox x:Name="ZBox"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </Border>

</UserControl>