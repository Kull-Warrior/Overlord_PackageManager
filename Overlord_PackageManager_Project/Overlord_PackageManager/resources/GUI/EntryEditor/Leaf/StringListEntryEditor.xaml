<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.StringListEntryEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="LinesBox"
             Grid.Row="0"
             Margin="10"
             AcceptsReturn="True"
             AcceptsTab="True"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             TextWrapping="NoWrap"
             FontFamily="Consolas"
             TextChanged="LinesBox_TextChanged"/>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Content="Export TXT"
                Grid.Column="0"
                Margin="0,0,5,0"
                Click="Export_Click"/>

            <Button Content="Import TXT"
                Grid.Column="1"
                Margin="5,0,0,0"
                Click="Import_Click"/>

        </Grid>
    </Grid>

</UserControl>