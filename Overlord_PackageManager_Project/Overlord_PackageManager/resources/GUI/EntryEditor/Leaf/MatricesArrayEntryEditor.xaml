<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.MatricesArrayEntryEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="10">

                <TextBlock Text="Matrices Array"
               FontWeight="Bold"
               FontSize="16"
               Margin="0,0,0,10"/>

                <StackPanel x:Name="EditorContainer"/>

                <Button x:Name="AddButton"
        Content="Add Matrix"
        Width="120"
        Margin="0,10,0,0"
        Click="AddButton_Click"/>

            </StackPanel>

        </ScrollViewer>

        <!-- Import / Export -->
        <Grid Grid.Row="1"
              Margin="5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Content="Export BIN"
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    Click="Export_Click"/>

            <Button Content="Import BIN"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="Import_Click"/>

        </Grid>

    </Grid>

</UserControl>