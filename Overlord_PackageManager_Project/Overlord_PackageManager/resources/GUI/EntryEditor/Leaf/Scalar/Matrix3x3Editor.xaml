<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.Scalar.Matrix3x3Editor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Padding="10">
        <StackPanel>

            <TextBlock x:Name="LabelBlock"
                       Text="Matrix3x3"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- Row 1 -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M11" FontWeight="SemiBold"/>
                        <TextBox x:Name="M11Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M12" FontWeight="SemiBold"/>
                        <TextBox x:Name="M12Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M13" FontWeight="SemiBold"/>
                        <TextBox x:Name="M13Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 2 -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M21" FontWeight="SemiBold"/>
                        <TextBox x:Name="M21Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M22" FontWeight="SemiBold"/>
                        <TextBox x:Name="M22Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M23" FontWeight="SemiBold"/>
                        <TextBox x:Name="M23Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 3 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M31" FontWeight="SemiBold"/>
                        <TextBox x:Name="M31Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M32" FontWeight="SemiBold"/>
                        <TextBox x:Name="M32Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="8"
                        BorderThickness="1"
                        BorderBrush="#444"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="M33" FontWeight="SemiBold"/>
                        <TextBox x:Name="M33Box"
                                 TextChanged="AnyTextChanged"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </Border>

</UserControl>