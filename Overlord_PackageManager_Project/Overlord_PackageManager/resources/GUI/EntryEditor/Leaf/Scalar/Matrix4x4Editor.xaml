<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.Scalar.Matrix4x4Editor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="10">
        <StackPanel>

            <TextBlock x:Name="LabelBlock"
                       Text="Matrix"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M11" FontWeight="SemiBold"/>
                            <TextBox x:Name="M11Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M12" FontWeight="SemiBold"/>
                            <TextBox x:Name="M12Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M13" FontWeight="SemiBold"/>
                            <TextBox x:Name="M13Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M14" FontWeight="SemiBold"/>
                            <TextBox x:Name="M14Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M21" FontWeight="SemiBold"/>
                            <TextBox x:Name="M21Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M22" FontWeight="SemiBold"/>
                            <TextBox x:Name="M22Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M23" FontWeight="SemiBold"/>
                            <TextBox x:Name="M23Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M24" FontWeight="SemiBold"/>
                            <TextBox x:Name="M24Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 3 -->
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M31" FontWeight="SemiBold"/>
                            <TextBox x:Name="M31Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M32" FontWeight="SemiBold"/>
                            <TextBox x:Name="M32Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M33" FontWeight="SemiBold"/>
                            <TextBox x:Name="M33Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M34" FontWeight="SemiBold"/>
                            <TextBox x:Name="M34Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 4 -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M41" FontWeight="SemiBold"/>
                            <TextBox x:Name="M41Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M42" FontWeight="SemiBold"/>
                            <TextBox x:Name="M42Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M43" FontWeight="SemiBold"/>
                            <TextBox x:Name="M43Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="M44" FontWeight="SemiBold"/>
                            <TextBox x:Name="M44Box" TextChanged="AnyTextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock x:Name="TranslationBlock"
                       Margin="0,10,0,0"
                       FontFamily="Consolas"/>

        </StackPanel>
    </Border>

</UserControl>