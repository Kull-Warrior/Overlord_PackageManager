<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Leaf.VertexAttributeEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Padding="10">
        <StackPanel>
            <TextBlock x:Name="LabelBlock"
                       Text="Vertex Attribute"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Type (byte)" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="TypeBox" TextChanged="AnyTextChanged" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Index (byte)" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="IndexBox" TextChanged="AnyTextChanged" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="0,0,8,0" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Semantic" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="SemanticBox" SelectionChanged="AnySelectionChanged" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="8" BorderThickness="1" BorderBrush="#444" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="ByteSize" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="SizeBox" SelectionChanged="AnySelectionChanged" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="RawBlock"
                       Margin="0,10,0,0"
                       FontFamily="Consolas"
                       Text="Raw: 0x00000000" />
        </StackPanel>
    </Border>
</UserControl>