<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.XML.XMLAssetEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- filename -->
                <RowDefinition Height="*"/>
                <!-- XML editor -->
            </Grid.RowDefinitions>

            <ContentControl x:Name="HeaderPanel" Grid.Row="0"/>

            <ContentControl x:Name="EditorHost" Grid.Row="1"/>
        </Grid>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Content="Export XML"
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    Click="Export_Click"/>

            <Button Content="Import XML"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="Import_Click"/>
        </Grid>

    </Grid>
</UserControl>