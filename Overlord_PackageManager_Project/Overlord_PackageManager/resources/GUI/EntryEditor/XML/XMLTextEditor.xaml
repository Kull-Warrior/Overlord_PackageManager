<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.XML.XMLTextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <TextBox x:Name="XmlBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextChanged="XmlBox_TextChanged"/>
    </Grid>

</UserControl>