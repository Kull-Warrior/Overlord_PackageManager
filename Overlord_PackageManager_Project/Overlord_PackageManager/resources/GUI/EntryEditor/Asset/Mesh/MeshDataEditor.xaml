<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Asset.Mesh.MeshDataEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helixSharp="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.Wpf.SharpDX">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabControl"
                    Grid.Row="0"
                    Margin="8"
                    SelectionChanged="MainTabControl_SelectionChanged">

            <TabItem Header="3D Preview">
                <helixSharp:Viewport3DX x:Name="Viewport"
                Background="#1E1E1E"
                EffectsManager="{Binding EffectsManager}">

                    <helixSharp:Viewport3DX.Camera>
                        <helixSharp:PerspectiveCamera Position="10,10,10"
                              LookDirection="-10,-10,-10"
                              UpDirection="0,1,0" />
                    </helixSharp:Viewport3DX.Camera>

                </helixSharp:Viewport3DX>
            </TabItem>

            <TabItem Header="UV Preview">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="UvImage"
                           Stretch="None"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Info">
                <ScrollViewer>
                    <StackPanel x:Name="RootPanel"
                                Margin="10"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Grid Grid.Row="1"
              Margin="8">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="ImportButton"
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    Content="Import"
                    Click="Import_Click"/>

            <Button x:Name="ExportButton"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Content="Export"
                    Click="Export_Click"/>

        </Grid>
    </Grid>
</UserControl>