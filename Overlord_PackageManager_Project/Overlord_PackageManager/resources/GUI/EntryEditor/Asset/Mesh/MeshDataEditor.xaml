<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Asset.Mesh.MeshDataEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="http://helix-toolkit.org/wpf">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabControl" Grid.Row="0" Margin="8" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="3D Preview">
                <helix:HelixViewport3D x:Name="Viewport"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowFrameRate="True">
                    <helix:DefaultLights />
                </helix:HelixViewport3D>
            </TabItem>

            <TabItem Header="UV Preview">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="UvImage" Stretch="None"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Info">
                <ScrollViewer>
                    <StackPanel x:Name="RootPanel" Margin="10"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="ImportButton" Content="Import" Grid.Column="0" Margin="0,0,5,0" Click="Import_Click"/>
            <Button x:Name="ExportButton" Content="Export" Grid.Column="1" Margin="5,0,0,0" Click="Export_Click"/>
        </Grid>
    </Grid>
</UserControl>