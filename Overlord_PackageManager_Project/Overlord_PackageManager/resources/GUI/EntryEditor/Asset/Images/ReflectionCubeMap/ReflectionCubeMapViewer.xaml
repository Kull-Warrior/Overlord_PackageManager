<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Asset.Images.ReflectionCubeMap.ReflectionCubeMapViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Label -->
            <RowDefinition Height="Auto"/>
            <!-- Mip selector -->
            <RowDefinition Height="Auto"/>
            <!-- Preview -->
        </Grid.RowDefinitions>

        <!-- Section Title -->
        <TextBlock Grid.Row="0"
                   Text="Reflection Cubemap"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- Mip Selector -->
        <ComboBox x:Name="MipSelector"
                  Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,8"/>

        <!-- Preview Grid -->
        <Grid x:Name="PreviewGrid"
              Grid.Row="2"
              HorizontalAlignment="Stretch"
              Margin="0,5,0,0"/>
    </Grid>
</UserControl>