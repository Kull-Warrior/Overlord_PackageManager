<UserControl x:Class="Overlord_PackageManager.resources.GUI.EntryEditor.Asset.Images.DDS.DDSMipChainEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Section Label -->
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Image -->
            <RowDefinition Height="Auto"/>
            <!-- Dropdown -->
        </Grid.RowDefinitions>

        <!-- Section Title -->
        <TextBlock Grid.Row="0"
                   Text="Mip Map Chain"
                   FontWeight="Bold"
                   Margin="0,0,0,8"
                   HorizontalAlignment="Left"/>

        <!-- Width | Format | Height -->
        <Grid Grid.Row="1"
              Width="256"
              HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="WidthText"
                       Grid.Column="0"
                       HorizontalAlignment="Left"
                       FontFamily="Consolas"
                       FontSize="13"/>

            <TextBlock x:Name="FormatText"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       FontFamily="Consolas"
                       FontSize="13"
                       FontWeight="SemiBold"/>

            <TextBlock x:Name="HeightText"
                       Grid.Column="2"
                       HorizontalAlignment="Right"
                       FontFamily="Consolas"
                       FontSize="13"/>
        </Grid>

        <!-- Fixed 256x256 Preview -->
        <Border Grid.Row="2"
                Width="256"
                Height="256"
                BorderBrush="Gray"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,5,0,5">

            <Viewbox Stretch="Uniform">
                <Image x:Name="PreviewImage"
                       Stretch="Fill"
                       Cursor="Hand"
                       ToolTip="Double-click to open full-size viewer"/>
            </Viewbox>
        </Border>

        <!-- Mip Level Selector -->
        <ComboBox x:Name="MipSelector"
                  Grid.Row="3"
                  Width="256"
                  HorizontalAlignment="Center"
                  Margin="0,5,0,0"/>
    </Grid>
</UserControl>