<UserControl x:Class="Overlord_PackageManager.resources.EntryEditor.ReflectionCubeMapEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Content -->
            <RowDefinition Height="*" />
            <!-- Buttons -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable Content Area -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel x:Name="RootPanel"
                        Orientation="Vertical">

                <!-- Tag + Filename get injected here -->

                <TextBlock Text="Reflection Cubemap"
                           FontWeight="Bold"
                           Margin="10,10,10,5"/>

                <!-- Mip Selector -->
                <ComboBox x:Name="MipSelector"
                          Width="150"
                          Margin="0,0,0,10"/>

                <!-- Preview Grid -->
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,10,0,10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="ImgTop"
                           Grid.Row="0"
                           Grid.Column="1"
                           MaxWidth="128"
                           MaxHeight="128"/>

                    <Image x:Name="ImgLeft"
                           Grid.Row="1"
                           Grid.Column="0"
                           MaxWidth="128"
                           MaxHeight="128"/>

                    <Image x:Name="ImgFront"
                           Grid.Row="1"
                           Grid.Column="1"
                           MaxWidth="128"
                           MaxHeight="128"/>

                    <Image x:Name="ImgRight"
                           Grid.Row="1"
                           Grid.Column="2"
                           MaxWidth="128"
                           MaxHeight="128"/>

                    <Image x:Name="ImgBack"
                           Grid.Row="1"
                           Grid.Column="3"
                           MaxWidth="128"
                           MaxHeight="128"/>

                    <Image x:Name="ImgBottom"
                           Grid.Row="2"
                           Grid.Column="1"
                           MaxWidth="128"
                           MaxHeight="128"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Export LEFT -->
            <Button x:Name="BtnExport"
                    Content="Export Reflection Cubemap"
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    Padding="5"/>

            <!-- Import RIGHT -->
            <Button x:Name="BtnImport"
                    Content="Import Reflection Cubemap"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Padding="5"/>
        </Grid>
    </Grid>
</UserControl>