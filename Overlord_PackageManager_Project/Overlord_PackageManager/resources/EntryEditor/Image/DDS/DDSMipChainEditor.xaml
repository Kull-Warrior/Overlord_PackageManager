<UserControl x:Class="Overlord_PackageManager.resources.EntryEditor.DDSMipChainEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Width / Height Header -->
        <Grid Grid.Row="0" Width="256" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Width -->
            <TextBlock x:Name="WidthText"
               Grid.Column="0"
               HorizontalAlignment="Left"
               FontFamily="Consolas"
               FontSize="13"/>

            <!-- Format (centered) -->
            <TextBlock x:Name="FormatText"
               Grid.Column="1"
               HorizontalAlignment="Center"
               FontFamily="Consolas"
               FontSize="13"
               FontWeight="SemiBold"/>

            <!-- Height -->
            <TextBlock x:Name="HeightText"
               Grid.Column="2"
               HorizontalAlignment="Right"
               FontFamily="Consolas"
               FontSize="13"/>
        </Grid>

        <!-- Fixed 256x256 preview -->
        <Border Grid.Row="1"
                Width="256"
                Height="256"
                BorderBrush="Gray"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,5,0,5">

            <Viewbox Stretch="Uniform">
                <Image x:Name="PreviewImage"
                       Stretch="Fill"/>
            </Viewbox>
        </Border>

        <!-- Mip selector -->
        <ComboBox x:Name="MipSelector"
                  Grid.Row="2"
                  Width="256"
                  HorizontalAlignment="Center"
                  Margin="0,5,0,0"/>
    </Grid>
</UserControl>